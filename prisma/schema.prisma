generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String

  plan      String   @default("FREE")
  createdAt DateTime @default(now())

  usages Usage[] // ✅ OVO JE FALILO
}

model Usage {
  id     String @id @default(cuid())
  userId String
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Lead {
  id        String   @id @default(uuid())
  message   String
  response  String?
  createdAt DateTime @default(now())
}
model Plan {
  id        Int      @id @default(autoincrement())
  goal      String
  weight    Int
  height    Int
  activity  String
  result    String
  createdAt DateTime @default(now())
}